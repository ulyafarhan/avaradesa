APP_NAME="AvaraDesa"
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database Configuration
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=avaradesa
DB_USERNAME=
DB_PASSWORD=

# Session & Cache
SESSION_DRIVER=file
SESSION_LIFETIME=120
# SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync


# Token expiration (minutes). Default: 525600 (1 year)
# SANCTUM_TOKEN_EXPIRATION=525600

CACHE_STORE=file
CACHE_PREFIX=avaradesa

# Redis Configuration
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail Configuration
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL="${APP_URL}/api/v1/telegram/webhook"
TELEGRAM_WEBHOOK_SECRET=

# --- WHATSAPP GATEWAY (VPS) ---
WHA_PROVIDER=wa-gateway          # wa-gateway | fonnte
WHA_GATEWAY_URL=http://localhost:2785
WHA_API_KEY=
WHA_SESSION_ID=default

# --- FONNTE (alternatif WhatsApp, tanpa VPS) ---
FONNTE_TOKEN=

# AI Provider Configuration (gemini or openai)
AI_PROVIDER=gemini

# Gemini AI Configuration
GEMINI_API_KEY=
GEMINI_MODEL=gemini-pro

# OpenAI / TokenRouter / Custom OpenAI-compatible Provider Configuration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Kemendagri API (Optional)
KEMENDAGRI_API_URL=
KEMENDAGRI_API_KEY=

# Cloud Storage (R2 / S3 — active storage untuk production)
# Set FILESYSTEM_DISK=cloud untuk mengaktifkan, lalu pilih penyedia:
#   - cloud = r2  (Cloudflare R2, S3-compatible)
#   - cloud = s3  (Amazon S3)
FILESYSTEM_CLOUD=r2
CLOUD_ACCESS_KEY_ID=
CLOUD_SECRET_ACCESS_KEY=
CLOUD_REGION=auto
CLOUD_BUCKET=
CLOUD_URL=
CLOUD_ENDPOINT=
CLOUD_USE_PATH_STYLE_ENDPOINT=false

# AWS (Fallback — hanya dipakai jika FILESYSTEM_CLOUD=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Reverb (WebSocket)
REVERB_APP_ID=avaradesa
REVERB_APP_KEY=avaradesa-key
REVERB_APP_SECRET=avaradesa-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

# Frontend Environment Variables
VITE_API_BASE_URL="${APP_URL}/api"
VITE_APP_ENV="${APP_ENV}"
